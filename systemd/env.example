# /etc/hobe-radius-proxy/env
# انسخ هذا الملف إلى /etc/hobe-radius-proxy/env واملأ القيم

# عنوان لوحة التراخيص (مطلوب)
ADMIN_BASE_URL=https://panel.hoberadius.com

# السر المشترك بين الوكيل ولوحة التراخيص (مطلوب)
# يجب أن يطابق RADIUS_PROXY_SHARED_SECRET في لوحة التراخيص
RADIUS_PROXY_SHARED_SECRET=changeme-generate-with-openssl-rand-hex-32

# السر المشترك بين عقد CHR والوكيل (مطلوب)
# يُضبَط في إعدادات RADIUS Client على كل CHR بنفس هذه القيمة
PROXY_CHR_SECRET=changeme-chr-secret

# معرّف هذا الوكيل (اختياري — يُولَّد تلقائيًا)
PROXY_ID=proxy-01

# إعدادات الاستماع (اختيارية)
# PROXY_LISTEN_HOST=0.0.0.0
# PROXY_AUTH_PORT=1812
# PROXY_ACCT_PORT=1813
# PROXY_ROUTING_REFRESH=60
# PROXY_LOG_LEVEL=INFO
# PROXY_LOG_REALMS=true
